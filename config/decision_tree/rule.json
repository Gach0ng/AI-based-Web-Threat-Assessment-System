      "category": "商标滥用",
      "risk_level": "低危",
      "reasons": ["ICP备案主体为企业", "YOLO/OCR非空"]
    },
    {
      "id": "result_trademark_abuse_icp_2",
      "type": "result",
      "category": "商标滥用",
      "risk_level": "低危",
      "reasons": ["ICP备案主体为企业", "YOLO/OCR非空"]
    },
    {
      "id": "result_trademark_abuse_wd",
